<body>
{% include 'header.njk' %}
   {{content | safe}} 
{% include 'footer.njk' %}
<script>
  // Cursor-tracked glow on category tiles
  document.getElementById('catGrid')?.addEventListener('mousemove', (e) => {
    const tile = e.target.closest('[data-tile]');
    if (!tile) return;
    const r = tile.getBoundingClientRect();
    tile.style.setProperty('--mx', (e.clientX - r.left) + 'px');
    tile.style.setProperty('--my', (e.clientY - r.top) + 'px');
  });

 <!-- Language Switching Engine -->
function switchLanguage(lang, button) {
            // Update active state class on buttons
            document.querySelectorAll('.lang-btn').forEach(btn => btn.classList.remove('active'));
            button.classList.add('active');
            
            // Loop through and swap text contents based on target data-attributes
            document.querySelectorAll('[data-de]').forEach(element => {
                if (lang === 'en') {
                    element.textContent = element.getAttribute('data-en');
                } else {
                    element.textContent = element.getAttribute('data-de');
                }
            });
            
   // Adjust semantic document locale tag
            document.documentElement.lang = lang;
        }


</script>
</body>
</html>